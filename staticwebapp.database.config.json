{
  "$schema": "https://github.com/Azure/data-api-builder/releases/download/v1.1.7/dab.draft.schema.json",
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/data-api"
    }
  },
  "entities": {
    "Tour": {
      "source": "tbl_Touren",
      "permissions": [
        {
          "role": "anonymous",
          "actions": ["read"]
        }
      ],
      "mappings": {
        "TourID": "id",
        "TourCode": "TourCode",
        "Titel": "Titel",
        "Region": "Region",
        "Beschreibung_Kurz": "Beschreibung_Kurz",
        "Basispreis_Netto_EK": "Basispreis_Netto_EK",
        "Basispreis_Brutto_VK": "Basispreis_Brutto_VK"
      }
    }
  }
